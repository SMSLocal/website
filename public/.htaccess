# SMSLocal — Apache .htaccess
# ─────────────────────────────────────────────────────────────────────────────
# This file is ONLY honoured when the site is hosted on an Apache server
# (e.g. shared hosting, cPanel, traditional VPS). On Vercel / Next.js it is
# ignored — `proxy.ts`, `next.config.mjs`, and `app/robots.ts` cover the
# same ground there.
#
# Sections:
#   1. Force HTTPS (no plaintext HTTP)
#   2. Force the canonical "www." host
#   3. Long-term cache for static assets
#   4. Compression for HTML/CSS/JS/JSON
#   5. Security headers (HSTS, X-Frame-Options, etc.)
#   6. Block direct access to dotfiles
#   7. Custom 404 page
# ─────────────────────────────────────────────────────────────────────────────

Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Force canonical host (www.smslocal.in)
    RewriteCond %{HTTP_HOST} ^smslocal\.in$ [NC]
    RewriteRule ^ https://www.smslocal.in%{REQUEST_URI} [L,R=301]

    # 3. Strip trailing slashes (except for the root)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ /$1 [L,R=301]
</IfModule>

# 3. Long-term cache for hashed/static assets
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/jpeg            "access plus 1 year"
    ExpiresByType image/png             "access plus 1 year"
    ExpiresByType image/webp            "access plus 1 year"
    ExpiresByType image/avif            "access plus 1 year"
    ExpiresByType image/svg+xml         "access plus 1 year"
    ExpiresByType image/x-icon          "access plus 1 year"

    # Fonts
    ExpiresByType font/woff             "access plus 1 year"
    ExpiresByType font/woff2            "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"

    # CSS / JS
    ExpiresByType text/css              "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript       "access plus 1 year"

    # HTML (short — let revalidation kick in)
    ExpiresByType text/html             "access plus 0 seconds"
    ExpiresByType application/xml       "access plus 0 seconds"
    ExpiresByType text/xml              "access plus 0 seconds"

    # Sitemap & robots
    <FilesMatch "^(sitemap\.xml|robots\.txt)$">
        ExpiresDefault "access plus 1 hour"
    </FilesMatch>
</IfModule>

# 4. GZIP / Brotli compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# 5. Security headers
<IfModule mod_headers.c>
    # HSTS — force HTTPS for 1 year, include subdomains
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Click-jacking protection
    Header always set X-Frame-Options "SAMEORIGIN"

    # MIME-sniffing protection
    Header always set X-Content-Type-Options "nosniff"

    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy — opt out of features we never use
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self)"

    # Remove server fingerprint headers
    Header unset X-Powered-By
    Header unset Server

    # Strip cache headers off dynamic HTML so SEO admin toggles propagate
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
</IfModule>

# 6. Block direct access to dotfiles & sensitive files
<FilesMatch "^\.(?!well-known\/)">
    Require all denied
</FilesMatch>
<FilesMatch "(package\.json|package-lock\.json|pnpm-lock\.yaml|tsconfig\.json|next\.config\..*|\.env.*)$">
    Require all denied
</FilesMatch>

# 7. Custom error pages (Next.js renders these via app/not-found.tsx)
ErrorDocument 404 /404
ErrorDocument 500 /500
